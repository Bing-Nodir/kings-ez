    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:push:postgres": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:migrate:postgres": "prisma migrate deploy --schema prisma/schema.postgres.prisma",
    "db:seed:postgres": "prisma generate --schema prisma/schema.postgres.prisma && node prisma/seed.js"
  },
  "dependencies": {
